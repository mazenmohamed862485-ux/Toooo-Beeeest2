<?xml version="1.0" encoding="utf-8"?>
<!--
  TO Best — AndroidManifest.xml
  Permissions: Internet, Notifications, Pedometer, Camera, Storage
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ── Permissions ───────────────────────────────────────── -->

    <!-- شبكة الإنترنت -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- الإشعارات (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- الـ Pedometer (خطوات) -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />
    <uses-permission android:name="com.google.android.gms.permission.ACTIVITY_RECOGNITION" />

    <!-- الكاميرا والتخزين للصور -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- تسجيل الصوت (Voice Messages) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- الـ Background Tasks -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <!-- الاهتزاز للإشعارات -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:label="TO Best"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:enableOnBackInvokedCallback="true"
        android:requestLegacyExternalStorage="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize"
            android:screenOrientation="portrait">

            <!-- حماية من تسجيل الشاشة — يُطبَّق عبر flutter_windowmanager -->

            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep Links لـ TO Best -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="tobest"
                    android:host="app" />
            </intent-filter>
        </activity>

        <!-- Flutter Engine -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- Workmanager Background Service -->
        <service
            android:name="androidx.work.impl.background.systemalarm.SystemAlarmService"
            android:exported="false"
            android:directBootAware="false"
            android:enabled="@bool/enable_system_alarm_service_default" />

        <!-- Boot Receiver للـ WorkManager -->
        <receiver
            android:name="androidx.work.impl.background.systemalarm.ConstraintProxy$BatteryNotLowProxy"
            android:enabled="false"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BATTERY_OKAY" />
                <action android:name="android.intent.action.BATTERY_LOW" />
            </intent-filter>
        </receiver>

        <!-- إشعارات WorkManager -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

    <!-- minSdkVersion 24 -->
    <uses-sdk android:minSdkVersion="24" />

</manifest>
